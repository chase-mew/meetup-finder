# Copy this file to .dev.vars and fill in your key.
# Enable on the key: Geocoding API, Places API (New), Routes API.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional observability settings.
# Set a Sentry DSN to report Worker errors; leave empty to disable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
# Minimum log level: debug | info | warn | error (defaults to info).
# LOG_LEVEL=debug
