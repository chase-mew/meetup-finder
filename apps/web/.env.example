# Copy to .env.local for local overrides.
#
# Leave empty for local development: the Vite dev server proxies /api to the
# Worker on http://localhost:8787 automatically.
#
# For a deployed build, set this to your deployed Worker URL, for example:
# VITE_API_BASE_URL=https://meetup-finder-api.your-subdomain.workers.dev
VITE_API_BASE_URL=
